# Build
BUILD_CONTEXT=.
DOCKERFILE_PATH=Dockerfile
BASE_IMAGE=lscr.io/linuxserver/chrome:latest
IMAGE_NAME=opencli-chrome:local
CONTAINER_NAME=opencli-chrome

# Extension build settings
OPENCLI_EXTENSION_VERSION=v1.7.0
# Leave empty to derive the download URL from OPENCLI_EXTENSION_VERSION.
OPENCLI_EXTENSION_URL=
OPENCLI_EXTENSION_DIR=/opt/opencli-extension
OPENCLI_EXTENSION_CRX=/opt/opencli-extension.crx
OPENCLI_EXTENSION_PREFS_DIR=/usr/share/google-chrome/extensions

# Node and OpenCLI
NODEJS_VERSION=lts 24
N_PREFIX=/root/n
OPENCLI_NPM_PACKAGE=@jackwener/opencli

# Runtime
PUID=1000
PGID=1000
TZ=Asia/Shanghai
CHROME_USER=abc
CHROME_PASSWORD=CHANGE_ME
CONFIG_DIR=./config
HOST_BIND_IP=0.0.0.0

# Published ports
CHROME_HTTP_PORT=3000
CHROME_HTTPS_PORT=3001
CHROME_WS_PORT=8082
CHROME_DEBUG_PORT=9222

# Optional Chrome proxy settings
CHROME_PROXY_SERVER=
CHROME_PROXY_BYPASS_LIST=

# Chrome flags
CHROME_REMOTE_DEBUGGING_ADDRESS=0.0.0.0
CHROME_REMOTE_DEBUGGING_PORT=9222
CHROME_DEBUG_FORWARD_PORT=9223
CHROME_REMOTE_DEBUGGING_USER_DATA_DIR=/config/chrome-cdt-profile
CHROME_START_PAGE=about:blank
CHROME_EXTRA_FLAGS=


# Selkies stream tuning
# These defaults favor lower bandwidth and CPU load for remote servers.
SELKIES_FRAMERATE=20
SELKIES_ENABLE_RATE_CONTROL=true
SELKIES_RATE_CONTROL_MODE=cbr
SELKIES_VIDEO_BITRATE=2
SELKIES_AUDIO_BITRATE=320000
SELKIES_IS_MANUAL_RESOLUTION_MODE=true
SELKIES_MANUAL_WIDTH=1280
SELKIES_MANUAL_HEIGHT=720
SELKIES_USE_CSS_SCALING=true
SELKIES_JPEG_QUALITY=60
SELKIES_H264_CRF=30
SELKIES_H264_PAINTOVER_CRF=30

# Container behavior
SHM_SIZE=1gb
RESTART_POLICY=unless-stopped
